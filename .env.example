# =====================================================
# ET Newsroom — Environment Variables
# =====================================================
# Copy this file to .env.local:
#   cp .env.example .env.local
# Then fill in your actual values below.
# NEVER commit .env.local to git.

# ── 1. SUPABASE (Required for auth + database) ───────
# Free forever. Sign up at: https://supabase.com
# After creating a project: Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ── 2. GROQ (Required for AI features) ───────────────
# Free tier: 14,400 requests/day. Sign up at: https://console.groq.com
# API Keys → Create API Key (starts with gsk_)
GROQ_API_KEY=gsk_your_groq_api_key_here

# ── 3. NEWSDATA.IO (Required for real news) ──────────
# Free tier: 200 requests/day. Sign up at: https://newsdata.io
# Dashboard → API Key (starts with pub_)
# Without this key, the app uses built-in mock news articles.
NEWSDATA_API_KEY=pub_your_newsdata_api_key_here

# ── 4. App URL (Required for OAuth redirect) ─────────
# Local dev: http://localhost:3000
# Production: https://your-domain.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000
